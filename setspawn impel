-- ============================================
-- 🚀 HYBRID FLY SYSTEM (ANTI-TP CHECK + HEIGHT FIX)
-- ============================================
local FlySystem = {}
local activeTween = nil
local currentTargetPos = nil
FlySystem.lastHrpPos = nil 

function FlySystem.Stop(hrp)
    if activeTween then
        activeTween:Cancel()
        activeTween = nil
        currentTargetPos = nil
    end
    FlySystem.lastHrpPos = nil
    
    if hrp then
        hrp.Anchored = false 
        hrp.Velocity = Vector3.zero
        hrp.AssemblyLinearVelocity = Vector3.zero
        hrp.AssemblyAngularVelocity = Vector3.zero
        local bv = hrp:FindFirstChild("FlyBV")
        if bv then bv.Velocity = Vector3.zero end
    end
end

function FlySystem.AdjustToTarget(hrp, targetPos, stopRadius, speed, goHigh)
    if not targetPos or not hrp then return false end
    stopRadius = stopRadius or Config.STOP_RADIUS
    local distance = (targetPos - hrp.Position).Magnitude
    
    if distance <= stopRadius then
        FlySystem.Stop(hrp)
        return true
    end

    -- 🛡️ Anti-Rubberband (ตรวจจับการโดนเซิร์ฟเวอร์ดึงกลับ)
    if FlySystem.lastHrpPos and (hrp.Position - FlySystem.lastHrpPos).Magnitude > 50 then
        if activeTween then
            activeTween:Cancel()
            activeTween = nil
            currentTargetPos = nil
            hrp.Anchored = false 
        end
    end
    FlySystem.lastHrpPos = hrp.Position 
    
    local myPos = hrp.Position
    local finalTarget = targetPos

    if goHigh or distance > 150 then
        local horizontalDist = (Vector3.new(targetPos.X, 0, targetPos.Z) - Vector3.new(myPos.X, 0, myPos.Z)).Magnitude
        
        local safeHeight = targetPos.Y + 600 
        if targetPos.Y < -1000 and myPos.Y < -1000 then 
            safeHeight = -1750 
        elseif targetPos.Y < -1000 and myPos.Y >= -1000 then
            safeHeight = 600
        end

        if horizontalDist > 60 then
            if myPos.Y < safeHeight - 15 then
                finalTarget = Vector3.new(myPos.X, safeHeight, myPos.Z)
            else
                finalTarget = Vector3.new(targetPos.X, safeHeight, targetPos.Z)
            end
        else
            finalTarget = targetPos
        end
    end

    local distToFinal = (finalTarget - hrp.Position).Magnitude

    local bv = hrp:FindFirstChild("FlyBV")
    if not bv then
        bv = Instance.new("BodyVelocity")
        bv.Name = "FlyBV"
        bv.MaxForce = Vector3.new(1e8, 1e8, 1e8)
        bv.Velocity = Vector3.zero
        bv.Parent = hrp
    end

    if distToFinal > 30 then
        bv.Velocity = Vector3.zero 
        
        local yDiff = math.abs(finalTarget.Y - hrp.Position.Y)
        local xzDiff = (Vector3.new(finalTarget.X, 0, finalTarget.Z) - Vector3.new(hrp.Position.X, 0, hrp.Position.Z)).Magnitude
        
        if yDiff > xzDiff and distToFinal > 30 then 
            hrp.Anchored = true
        else
            hrp.Anchored = false
        end

        if not currentTargetPos or (currentTargetPos - finalTarget).Magnitude > 5 or not activeTween or activeTween.PlaybackState ~= Enum.PlaybackState.Playing then
            if activeTween then activeTween:Cancel() end
            currentTargetPos = finalTarget
            
            local currentSpeed = speed or Config.FLY_SPEED
            local timeToReach = distToFinal / currentSpeed
            local tInfo = TweenInfo.new(timeToReach, Enum.EasingStyle.Linear)

            local lookPos = Vector3.new(finalTarget.X, hrp.Position.Y, finalTarget.Z)
            local lookRot = CFrame.new(hrp.Position)
            if (lookPos - hrp.Position).Magnitude > 0.1 then
                lookRot = CFrame.lookAt(hrp.Position, lookPos).Rotation
            else
                lookRot = CFrame.lookAt(hrp.Position, finalTarget).Rotation
            end

            activeTween = TweenService:Create(hrp, tInfo, {CFrame = CFrame.new(finalTarget) * lookRot})
            activeTween:Play()
        end
    else
        if activeTween then 
            activeTween:Cancel() 
            activeTween = nil
            currentTargetPos = nil
        end
        
        hrp.Anchored = false
        
        local currentSpeed = speed or Config.FLY_SPEED
        local dir = (finalTarget - hrp.Position).Unit
        bv.Velocity = dir * currentSpeed
        
        local lookPos = Vector3.new(finalTarget.X, hrp.Position.Y, finalTarget.Z)
        if (lookPos - hrp.Position).Magnitude > 0.1 then
            hrp.CFrame = CFrame.new(hrp.Position, lookPos)
        end
    end

    return false
end

-- ============================================
-- 📡 ระบบสแกนหาและกด ProximityPrompt (ระยะ 500)
-- ============================================
local function ScanAndPressPrompt(targetModel, maxSearchDistance)
    local char = LP.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end

    local closestPrompt = nil
    local shortestDist = maxSearchDistance or 500

    for _, obj in pairs(targetModel:GetDescendants()) do
        if obj:IsA("ProximityPrompt") and obj.Enabled then
            local parentPart = obj.Parent
            if parentPart and parentPart:IsA("BasePart") then
                local dist = (parentPart.Position - hrp.Position).Magnitude
                
                if dist <= shortestDist then
                    closestPrompt = obj
                    shortestDist = dist
                end
            end
        end
    end

    if closestPrompt then
        local key = closestPrompt.KeyboardKeyCode
        local holdTime = closestPrompt.HoldDuration
        local targetPos = closestPrompt.Parent.Position
        
        print("[System] 🕹️ เตรียมกดปุ่ม: " .. tostring(key.Name) .. " | ระยะ: " .. math.floor(shortestDist) .. " Studs")

        local lookDir = (targetPos - hrp.Position).Unit
        hrp.CFrame = CFrame.lookAt(hrp.Position, hrp.Position + Vector3.new(lookDir.X, 0, lookDir.Z))
        task.wait(0.3) 

        VirtualInputManager:SendKeyEvent(true, key, false, game)
        task.wait(holdTime + 0.1)
        VirtualInputManager:SendKeyEvent(false, key, false, game)
        
        return true
    else
        return false
    end
end

-- ============================================
-- 📍 MAIN MASTER LOGIC
-- ============================================
local function RunMasterDungeonScript()
    local char = LP.Character or LP.CharacterAdded:Wait()
    local hrp = char:WaitForChild("HumanoidRootPart", 9e9)
    local hum = char:WaitForChild("Humanoid", 9e9)

    repeat task.wait(0.5) until hum.Health > 0
    task.wait(1)

    -- ==================================
    -- 1️⃣ บินไป Set Spawn
    -- ==================================
    print("[System] 📍 [1/4] เดินทางไปจุดเกิด Impel Down...")
    while LP.Character == char and hrp and hum.Health > 0 do
        if FlySystem.AdjustToTarget(hrp, IMPEL_SPAWN_POINT, 3, Config.FLY_SPEED, true) then break end
        task.wait()
    end

    if hum.Health <= 0 then return end
    FlySystem.Stop(hrp)
    
    print("[System] ⏳ ถึงจุดเซ็ตเกิด! รอ 8 วินาทีเพื่อให้ Map & NPC โหลด...")
    task.wait(8)

    print("[System] 💬 ยิง Remote เซ็ตจุดเกิด...")
    pcall(function()
        QuestRemote:InvokeServer(unpack({{"npcChat", true}}))
        task.wait(0.5)
        for i = 1, 3 do SetSpawnRemote:FireServer() task.wait(0.3) end
        QuestRemote:InvokeServer(unpack({{"npcChat", false}}))
    end)
    print("[System] ✅ เซ็ตจุดเกิดสำเร็จ!")
    task.wait(1)

    -- ==================================
    -- 2️⃣ บินไปหน้าประตูดันเจี้ยน
    -- ==================================
    print("[System] 🚪 [2/4] เดินทางไปจุดลงดันเจี้ยน...")
    while LP.Character == char and hrp and hum.Health > 0 do
        if FlySystem.AdjustToTarget(hrp, IMPEL_DUNGEON_POINT, 3, Config.FLY_SPEED, true) then break end
        task.wait()
    end

    FlySystem.Stop(hrp)
    print("[System] 🏁 ถึงหน้าจุดลงดันเจี้ยนแล้ว! รอ 5 วินาทีให้ดันเจี้ยนโหลด...")
    task.wait(5) -- รอผู้เล่นวาร์ปเข้าดัน หรือรอแมพดันโหลด

    -- ==================================
    -- 3️⃣ ค้นหาและเก็บกุญแจ
    -- ==================================
    print("[System] 🔑 [3/4] เริ่มภารกิจค้นหากุญแจดันเจี้ยน...")
    local effectsFolder = workspace:FindFirstChild("Effects")
    if not effectsFolder then return end

    local keyModel = effectsFolder:WaitForChild("Key", 15) -- รอคีย์เกิด 15 วินาที
    local keyPart = keyModel and keyModel:FindFirstChild("Key")

    if keyModel and keyPart then
        print("[System] ✈️ เจอกุญแจ! กำลังบินไปเก็บ...")
        while LP.Character == char and hrp and hum.Health > 0 do
            if FlySystem.AdjustToTarget(hrp, keyPart.Position, 4, Config.FLY_SPEED, false) then break end
            task.wait()
        end
        FlySystem.Stop(hrp)
        task.wait(0.5)
        if ScanAndPressPrompt(keyModel, 500) then print("[System] ✅ เก็บกุญแจเรียบร้อย!") end
    else
        print("[System] ⚠️ ไม่พบกุญแจ (ข้ามไปขั้นตอนถัดไป)")
    end
    task.wait(1)

    -- ==================================
    -- 4️⃣ กวาดล้างหีบสมบัติทั้งหมด
    -- ==================================
    print("[System] 📦 [4/4] เริ่มกวาดล้างหีบสมบัติ...")
    local chestCount = 0

    for _, model in ipairs(effectsFolder:GetChildren()) do
        if model.Name ~= "Key" then
            local prompt = model:FindFirstChildWhichIsA("ProximityPrompt", true)
            if prompt and prompt.Enabled then
                chestCount = chestCount + 1
                local targetPos = prompt.Parent.Position
                
                print("[System] 💎 บินไปเปิดหีบใบที่ " .. chestCount .. "...")
                while LP.Character == char and hrp and hum.Health > 0 do
                    if FlySystem.AdjustToTarget(hrp, targetPos, 4, Config.FLY_SPEED, false) then break end
                    task.wait()
                end
                
                FlySystem.Stop(hrp)
                task.wait(0.5)

                if ScanAndPressPrompt(model, 500) then print("[System] ✅ เปิดหีบใบที่ " .. chestCount .. " สำเร็จ!") end
                task.wait(1)
            end
        end
    end

    if chestCount == 0 then
        print("[System] ⚠️ สแกนไม่พบหีบสมบัติเพิ่มเติมในห้องนี้")
    else
        print("[System] 🎉 ภารกิจดันเจี้ยนเสร็จสิ้น! เปิดหีบไปทั้งหมด " .. chestCount .. " กล่อง!")
    end

    -- ปิด Noclip
    if noclipConnection then noclipConnection:Disconnect() end
end

-- รันสคริปต์
task.spawn(RunMasterDungeonScript)
