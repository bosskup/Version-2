-- ============================================
-- 🚀 AUTO SET SPAWN & GO TO DUNGEON (IMPEL DOWN)
-- ============================================

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local LP = Players.LocalPlayer

local Events = ReplicatedStorage:WaitForChild("Events")
local QuestRemote = Events:WaitForChild("Quest")
local SetSpawnRemote = Events:WaitForChild("SetSpawn")
local SkillRemote = Events:WaitForChild("Skill")

-- ตั้งค่าพื้นฐานสำหรับระบบบิน
local Config = {
    FLY_SPEED = 70,
    STOP_RADIUS = 3.5,
    HEAD_OFFSET = 7
}

-- จุดเป้าหมาย
local IMPEL_SPAWN_POINT = Vector3.new(5937.7, 6.0, -9470.0)
local IMPEL_DUNGEON_POINT = Vector3.new(5883.0, 12.3, -10219.5)

-- ============================================
-- 🦅 ระบบ NOCLIP & GEPPO (ป้องกันการบินติดขัด / โดนดึงกลับ)
-- ============================================
local noclipConnection = RunService.Stepped:Connect(function()
    local char = LP.Character
    if char then
        for _, part in ipairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = false
            end
        end
    end
end)

task.spawn(function()
    while task.wait(0.5) do
        if LP.Character then
            local hrp = LP.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                pcall(function() 
                    SkillRemote:InvokeServer(unpack({
                        "Sky Walk2",
                        { char = LP.Character, cf = hrp.CFrame }
                    })) 
                end)
            end
        end
    end
end)

-- ============================================
-- 🚀 HYBRID FLY SYSTEM (V8 INTEGRATED + UP/DOWN ANCHOR)
-- ============================================
local FlySystem = {}
local activeTween = nil
local currentTargetPos = nil

function FlySystem.Stop(hrp)
    if activeTween then
        activeTween:Cancel()
        activeTween = nil
        currentTargetPos = nil
    end
    if hrp then
        hrp.Anchored = false -- ปลดล็อคตัวเสมอเมื่อหยุดบิน
        hrp.Velocity = Vector3.zero
        hrp.AssemblyLinearVelocity = Vector3.zero
        hrp.AssemblyAngularVelocity = Vector3.zero
        local bv = hrp:FindFirstChild("FlyBV")
        if bv then bv.Velocity = Vector3.zero end
    end
end

function FlySystem.Remove(hrp)
    FlySystem.Stop(hrp)
    if hrp then
        local bv = hrp:FindFirstChild("FlyBV")
        if bv then bv:Destroy() end
    end
end

function FlySystem.AdjustToTarget(hrp, targetPos, stopRadius, speed, goHigh)
    if not targetPos or not hrp then return false end
    stopRadius = stopRadius or Config.STOP_RADIUS
    local distance = (targetPos - hrp.Position).Magnitude
    
    if distance <= stopRadius then
        FlySystem.Stop(hrp)
        return true
    end
    
    local myPos = hrp.Position
    local finalTarget = targetPos

    -- 🌊 ระบบบิน 3-Phase แบบ Bypass V8
    if goHigh or distance > 150 then
        local horizontalDist = (Vector3.new(targetPos.X, 0, targetPos.Z) - Vector3.new(myPos.X, 0, myPos.Z)).Magnitude
        
        -- คำนวณเพดานบิน
        local safeHeight = myPos.Y + 500 
        if myPos.Y < -1000 and targetPos.Y < -1000 then 
            safeHeight = -1750 
        end

        if horizontalDist > 60 then
            if myPos.Y < safeHeight - 15 then
                finalTarget = Vector3.new(myPos.X, safeHeight, myPos.Z) -- Phase 1: บินขึ้นฟ้า
            else
                finalTarget = Vector3.new(targetPos.X, safeHeight, targetPos.Z) -- Phase 2: ข้ามแมพ
            end
        else
            finalTarget = targetPos -- Phase 3: ดิ่งลงดิน
        end
    end

    local distToFinal = (finalTarget - hrp.Position).Magnitude

    -- เตรียม BodyVelocity ไว้พยุงตัว
    local bv = hrp:FindFirstChild("FlyBV")
    if not bv then
        bv = Instance.new("BodyVelocity")
        bv.Name = "FlyBV"
        bv.MaxForce = Vector3.new(1e8, 1e8, 1e8)
        bv.Velocity = Vector3.zero
        bv.Parent = hrp
    end

    if distToFinal > 30 then
        -- 🚀 [ระยะไกล] ใช้ TWEEN เพื่อทะลุกำแพง
        bv.Velocity = Vector3.zero 
        
        -- ⚓ [ระบบ Anchor ตอนบินขึ้น/ลง แบบไดนามิก]
        local yDiff = math.abs(finalTarget.Y - hrp.Position.Y)
        local xzDiff = (Vector3.new(finalTarget.X, 0, finalTarget.Z) - Vector3.new(hrp.Position.X, 0, hrp.Position.Z)).Magnitude
        
        if yDiff > xzDiff and distToFinal > 30 then 
            -- บินในแนวตั้งมากกว่าแนวนอน = ล็อคตัวแข็ง
            hrp.Anchored = true
        else
            -- บินข้ามแมพ = ปลดล็อคตัว
            hrp.Anchored = false
        end

        if not currentTargetPos or (currentTargetPos - finalTarget).Magnitude > 5 or not activeTween or activeTween.PlaybackState ~= Enum.PlaybackState.Playing then
            if activeTween then activeTween:Cancel() end
            currentTargetPos = finalTarget
            
            local currentSpeed = speed or Config.FLY_SPEED
            local timeToReach = distToFinal / currentSpeed
            local tInfo = TweenInfo.new(timeToReach, Enum.EasingStyle.Linear)

            local lookPos = Vector3.new(finalTarget.X, hrp.Position.Y, finalTarget.Z)
            local lookRot = CFrame.new(hrp.Position)
            if (lookPos - hrp.Position).Magnitude > 0.1 then
                lookRot = CFrame.lookAt(hrp.Position, lookPos).Rotation
            else
                lookRot = CFrame.lookAt(hrp.Position, finalTarget).Rotation
            end

            activeTween = TweenService:Create(hrp, tInfo, {CFrame = CFrame.new(finalTarget) * lookRot})
            activeTween:Play()
        end
    else
        -- ⚔️ [ระยะใกล้/ฟาร์ม] ปิด Tween ใช้ BV + ปลดล็อคตัวเสมอ
        if activeTween then 
            activeTween:Cancel() 
            activeTween = nil
            currentTargetPos = nil
        end
        
        hrp.Anchored = false -- ปลดล็อคตอนเข้าตีมอน
        
        local currentSpeed = speed or Config.FLY_SPEED
        local dir = (finalTarget - hrp.Position).Unit
        bv.Velocity = dir * currentSpeed
        
        local lookPos = Vector3.new(finalTarget.X, hrp.Position.Y, finalTarget.Z)
        if (lookPos - hrp.Position).Magnitude > 0.1 then
            hrp.CFrame = CFrame.new(hrp.Position, lookPos)
        end
    end

    return false
end

function FlySystem.AdjustToMob(hrp, mob, headOffset)
    if not mob or not mob:FindFirstChild("HumanoidRootPart") then return false end
    local targetPos = mob.HumanoidRootPart.Position + Vector3.new(0, headOffset or Config.HEAD_OFFSET, 0)
    return FlySystem.AdjustToTarget(hrp, targetPos, 2, Config.FLY_SPEED)
end

function FlySystem.IsFlyingFar(hrp)
    if not currentTargetPos or not hrp then return false end
    return (hrp.Position - currentTargetPos).Magnitude > 30
end


-- ============================================
-- 📍 MAIN LOGIC : SET SPAWN -> GO TO DUNGEON
-- ============================================

local function DoSetSpawnAndGoDungeon()
    local char = LP.Character or LP.CharacterAdded:Wait()
    local hrp = char:WaitForChild("HumanoidRootPart", 9e9)
    local hum = char:WaitForChild("Humanoid", 9e9)

    -- รอจนกว่าตัวละครจะมีชีวิต (กันบัคเลือด 0)
    repeat task.wait(0.5) until hum.Health > 0
    task.wait(1)

    print("[System] 📍 กำลังเดินทางไปเซ็ตจุดเกิดที่ Impel Down...")

    -- 1️⃣ บินไปจุด Set Spawn
    while LP.Character == char and hrp and hum.Health > 0 do
        local isArrived = FlySystem.AdjustToTarget(hrp, IMPEL_SPAWN_POINT, 3, Config.FLY_SPEED, true)
        if isArrived then break end
        task.wait()
    end

    if hum.Health <= 0 then return end
    FlySystem.Stop(hrp)
    print("[System] 🎯 ถึงจุดเซ็ตเกิดแล้ว! กำลังคุยกับ NPC...")
    task.wait(7)

    -- 2️⃣ ทำการคุยกับ NPC เพื่อเซ็ตเกิด (อ้างอิงจากระบบเดิม)
    pcall(function()
        QuestRemote:InvokeServer(unpack({{"npcChat", true}}))
        task.wait(0.5)
        for i = 1, 3 do 
            SetSpawnRemote:FireServer() 
            task.wait(0.3) 
        end
        QuestRemote:InvokeServer(unpack({{"npcChat", false}}))
    end)

    print("[System] ✅ เซ็ตจุดเกิดสำเร็จ! รอ 1 วินาทีเพื่อไปจุดต่อไป...")
    task.wait(1)

    -- 3️⃣ บินไปหน้าดันเจี้ยน
    print("[System] 🚪 กำลังเดินทางไปจุดลงดันเจี้ยน...")
    while LP.Character == char and hrp and hum.Health > 0 do
        local isArrived = FlySystem.AdjustToTarget(hrp, IMPEL_DUNGEON_POINT, 3, Config.FLY_SPEED, true)
        if isArrived then break end
        task.wait()
    end

    FlySystem.Stop(hrp)
    print("[System] 🏁 ถึงหน้าจุดลงดันเจี้ยนเรียบร้อยแล้ว!")
    
    -- ลบ Noclip ออกเพื่อให้เดินลงดันได้ปกติ
    if noclipConnection then
        noclipConnection:Disconnect()
    end
end

-- สั่งเริ่มการทำงาน
task.spawn(DoSetSpawnAndGoDungeon)
