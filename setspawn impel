-- 📍 พิกัดเป้าหมาย (Impel Down)
local IMPEL_SPAWN_POINT = Vector3.new(5937.7, 6.0, -9470.0)
local FLY_SPEED = 70

-- 📡 Remotes สำหรับการเซ็ตจุดเกิด
local Events = ReplicatedStorage:WaitForChild("Events")
local QuestRemote = Events:WaitForChild("Quest")
local SetSpawnRemote = Events:WaitForChild("SetSpawn")

-- ============================================
-- 🦅 ระบบ NOCLIP (ปิดการชน)
-- ============================================
local function bypassOverlap(part)
    if part:IsA("BasePart") then
        part.CanCollide = false
        part.CanQuery = false
        part.CanTouch = false
        for _, child in pairs(part:GetChildren()) do
            if child:IsA("TouchTransmitter") then child:Destroy() end
        end
    end
end

local noclipConnection = RunService.Stepped:Connect(function()
    local char = LP.Character
    if char then
        for _, part in ipairs(char:GetDescendants()) do 
            bypassOverlap(part) 
        end
    end
end)

-- ============================================
-- 🚀 HYBRID FLY SYSTEM (V8 INTEGRATED + TWEEN)
-- ============================================
local FlySystem = {}
local activeTween = nil
local currentTargetPos = nil

function FlySystem.Stop(hrp)
    if activeTween then
        activeTween:Cancel()
        activeTween = nil
        currentTargetPos = nil
    end
    if hrp then
        hrp.Anchored = false
        hrp.Velocity = Vector3.zero
        hrp.AssemblyLinearVelocity = Vector3.zero
        hrp.AssemblyAngularVelocity = Vector3.zero
        local bv = hrp:FindFirstChild("FlyBV")
        if bv then bv:Destroy() end
    end
end

function FlySystem.AdjustToTarget(hrp, targetPos, stopRadius, speed, goHigh)
    if not targetPos or not hrp then return false end
    stopRadius = stopRadius or 3.5
    local distance = (targetPos - hrp.Position).Magnitude
    
    if distance <= stopRadius then
        FlySystem.Stop(hrp)
        return true
    end
    
    local myPos = hrp.Position
    local finalTarget = targetPos

    -- 🌊 ระบบบิน 3-Phase (บินขึ้นฟ้า -> ข้ามแมพ -> ดิ่งลงดิน)
    if goHigh or distance > 150 then
        local horizontalDist = (Vector3.new(targetPos.X, 0, targetPos.Z) - Vector3.new(myPos.X, 0, myPos.Z)).Magnitude
        
        local safeHeight = myPos.Y + 500 
        if myPos.Y < -1000 and targetPos.Y < -1000 then safeHeight = -1750 end

        if horizontalDist > 60 then
            if myPos.Y < safeHeight - 15 then
                finalTarget = Vector3.new(myPos.X, safeHeight, myPos.Z) -- Phase 1: บินขึ้นฟ้า
            else
                finalTarget = Vector3.new(targetPos.X, safeHeight, targetPos.Z) -- Phase 2: ข้ามแมพ
            end
        else
            finalTarget = targetPos -- Phase 3: ดิ่งลง
        end
    end

    local distToFinal = (finalTarget - hrp.Position).Magnitude

    local bv = hrp:FindFirstChild("FlyBV")
    if not bv then
        bv = Instance.new("BodyVelocity")
        bv.Name = "FlyBV"
        bv.MaxForce = Vector3.new(1e8, 1e8, 1e8)
        bv.Velocity = Vector3.zero
        bv.Parent = hrp
    end

    if distToFinal > 30 then
        -- 🚀 [ระยะไกล] ใช้ TWEEN เพื่อทะลุกำแพง
        bv.Velocity = Vector3.zero 
        
        local yDiff = math.abs(finalTarget.Y - hrp.Position.Y)
        local xzDiff = (Vector3.new(finalTarget.X, 0, finalTarget.Z) - Vector3.new(hrp.Position.X, 0, hrp.Position.Z)).Magnitude
        
        -- ล็อคตัวแข็งถ้าบินแนวตั้งมากกว่าแนวนอน
        if yDiff > xzDiff and distToFinal > 30 then 
            hrp.Anchored = true
        else
            hrp.Anchored = false
        end

        if not currentTargetPos or (currentTargetPos - finalTarget).Magnitude > 5 or not activeTween or activeTween.PlaybackState ~= Enum.PlaybackState.Playing then
            if activeTween then activeTween:Cancel() end
            currentTargetPos = finalTarget
            
            local currentSpeed = speed or FLY_SPEED
            local timeToReach = distToFinal / currentSpeed
            local tInfo = TweenInfo.new(timeToReach, Enum.EasingStyle.Linear)

            local lookPos = Vector3.new(finalTarget.X, hrp.Position.Y, finalTarget.Z)
            local lookRot = CFrame.new(hrp.Position)
            if (lookPos - hrp.Position).Magnitude > 0.1 then
                lookRot = CFrame.lookAt(hrp.Position, lookPos).Rotation
            else
                lookRot = CFrame.lookAt(hrp.Position, finalTarget).Rotation
            end

            activeTween = TweenService:Create(hrp, tInfo, {CFrame = CFrame.new(finalTarget) * lookRot})
            activeTween:Play()
        end
    else
        -- ⚔️ [ระยะใกล้] ปิด Tween ใช้ BodyVelocity แทน
        if activeTween then 
            activeTween:Cancel() 
            activeTween = nil
            currentTargetPos = nil
        end
        
        hrp.Anchored = false 
        local currentSpeed = speed or FLY_SPEED
        local dir = (finalTarget - hrp.Position).Unit
        bv.Velocity = dir * currentSpeed
        
        local lookPos = Vector3.new(finalTarget.X, hrp.Position.Y, finalTarget.Z)
        if (lookPos - hrp.Position).Magnitude > 0.1 then
            hrp.CFrame = CFrame.lookAt(hrp.Position, lookPos)
        end
    end

    return false
end

-- ============================================
-- 📍 MAIN LOGIC : บินไปเซ็ตจุดเกิด
-- ============================================
local function AutoSetSpawn()
    local char = LP.Character or LP.CharacterAdded:Wait()
    local hrp = char:WaitForChild("HumanoidRootPart", 9e9)
    local hum = char:WaitForChild("Humanoid", 9e9)
    
    repeat task.wait(0.5) until hum.Health > 0
    print("[System] 🚀 กำลังบินไปเซ็ตจุดเกิดที่พิกัดกำหนด...")

    -- ลูปบินจนกว่าจะถึงระยะ 3 หน่วยจากพิกัดเป้าหมาย
    while hum.Health > 0 and (hrp.Position - IMPEL_SPAWN_POINT).Magnitude > 3 do
        FlySystem.AdjustToTarget(hrp, IMPEL_SPAWN_POINT, 3, FLY_SPEED, true) -- true เพื่อเปิดโหมดบินขึ้นฟ้า
        task.wait()
    end

    -- หยุดบินเมื่อถึงที่หมาย
    FlySystem.Stop(hrp)
    task.wait(1)

    print("[System] 📍 ถึงจุดหมายแล้ว กำลังกดยืนยันจุดเกิด...")
    
    -- ทำการยิง Remote เพื่อคุยกับ NPC เซ็ตจุดเกิด
    pcall(function()
        QuestRemote:InvokeServer(unpack({{"npcChat", true}}))
        task.wait(0.5)
        for i = 1, 3 do 
            SetSpawnRemote:FireServer() 
            task.wait(0.3) 
        end
        QuestRemote:InvokeServer(unpack({{"npcChat", false}}))
    end)
    
    print("[System] ✅ เซ็ตจุดเกิดสำเร็จแล้ว!")
    
    -- ปิด Noclip หลังทำเสร็จเพื่อให้ตัวละครเล่นตามปกติได้
    if noclipConnection then
        noclipConnection:Disconnect()
    end
end

