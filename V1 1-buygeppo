local LevelManager = {}
function LevelManager.Get()
    local playerGui = LP:FindFirstChild("PlayerGui")
    if not playerGui then return 1 end
    local success, levelVal = pcall(function()
        return tonumber(playerGui.HUD.Main.Bars.Experience.Detail.Level.Text:match("%d+"))
    end)
    return (success and levelVal) and levelVal or 1
end

function LevelManager.GetBestQuest()
    local myLevel = LevelManager.Get()
    for _, data in ipairs(QUESTS) do
        if myLevel >= data.MinLevel and myLevel <= data.MaxLevel then return data end
    end
    return nil
end

local QuestTracker = {}
function QuestTracker.GetQuestName()
    local playerGui = LP:FindFirstChild("PlayerGui")
    if not playerGui then return nil end
    local questGui = playerGui:FindFirstChild("Quest")
    if questGui and questGui:FindFirstChild("Main") and questGui.Main:FindFirstChild("Info") and questGui.Main.Info:FindFirstChild("Top") then
        local qName = questGui.Main.Info.Top:FindFirstChild("QuestName")
        if qName and qName:IsA("TextLabel") then return qName.Text end
    end
    return nil
end

function QuestTracker.GetProgress()
    local playerGui = LP:FindFirstChild("PlayerGui")
    if not playerGui then return nil, nil end
    local questGui = playerGui:FindFirstChild("Quest")
    if not questGui then return nil, nil end

    local function scan(obj)
        for _, child in ipairs(obj:GetChildren()) do
            if child:IsA("TextLabel") or child:IsA("TextButton") then
                local text = child.Text
                if text then
                    local current, total = text:match("(%d+)/(%d+)")
                    if current and total then return tonumber(current), tonumber(total) end
                    current, total = text:match("(%d+) of (%d+)")
                    if current and total then return tonumber(current), tonumber(total) end
                end
            end
            local c, t = scan(child)
            if c then return c, t end
        end
        return nil, nil
    end
    return scan(questGui)
end

function QuestTracker.IsComplete()
    local current, total = QuestTracker.GetProgress()
    if current and total and total > 0 then return current >= total end
    local playerGui = LP:FindFirstChild("PlayerGui")
    local questGui = playerGui and playerGui:FindFirstChild("Quest")
    if questGui then
        local function checkText(obj)
            for _, child in ipairs(obj:GetChildren()) do
                if child:IsA("TextLabel") or child:IsA("TextButton") then
                    local text = (child.Text or ""):lower()
                    if text:find("return") or text:find("completed") or text:find("done") or text:find("talk to") then
                        return true
                    end
                end
                if checkText(child) then return true end
            end
            return false
        end
        if checkText(questGui) then return true end
    end
    return false
end

function QuestTracker.UpdateHasActiveQuest()
    local playerGui = LP:FindFirstChild("PlayerGui")
    if not playerGui then cachedHasQuest = false return end
    local questGui = playerGui:FindFirstChild("Quest")
    if not questGui then cachedHasQuest = false return end
    local main = questGui:FindFirstChild("Main")
    if questGui:IsA("ScreenGui") and not questGui.Enabled then cachedHasQuest = false return end
    if main and not main.Visible then cachedHasQuest = false return end
    local name = QuestTracker.GetQuestName()
    if not name or name:gsub("%s", "") == "" or name:lower():find("none") or name:lower():find("no quest") or name == "QuestName" or name == "Label" then 
        cachedHasQuest = false
    else
        cachedHasQuest = true
    end
end

