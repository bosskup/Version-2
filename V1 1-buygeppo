local SetSpawnManager = {}
SetSpawnManager.LastSpawnNPC = nil
function SetSpawnManager.DoSetSpawn(quest)
    if not quest or not quest.SpawnPoint then return end
    if SetSpawnManager.LastSpawnNPC == quest.NPCId then return end
    local char = LP.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    local hum = char and char:FindFirstChild("Humanoid")
    if not hrp or not hum then return end
    local startTime = tick()
    while _G.SystemEnabled and not _G.IsBuyingGeppo and LP.Character == char and hrp.Parent and hum.Health > 0 and (hrp.Position - quest.SpawnPoint).Magnitude > 3 do
        FlySystem.AdjustToTarget(hrp, quest.SpawnPoint, 3, Config.FLY_SPEED, true)
        task.wait()
        if tick() - startTime > 120 then break end
    end
    if not _G.SystemEnabled or _G.IsBuyingGeppo or hum.Health <= 0 then return end
    FlySystem.Stop(hrp)
    task.wait(1)
    pcall(function()
        QuestRemote:InvokeServer(unpack({{"npcChat", true}}))
        task.wait(0.5)
        for i = 1, 3 do SetSpawnRemote:FireServer() task.wait(0.3) end
        QuestRemote:InvokeServer(unpack({{"npcChat", false}}))
    end)
    SetSpawnManager.LastSpawnNPC = quest.NPCId
end

local QuestManager = {}
function QuestManager.AutoAcceptQuest()
    local quest = LevelManager.GetBestQuest()
    if not quest then return nil end
    local char = LP.Character 
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    local hum = char and char:FindFirstChild("Humanoid")
    if not hrp or not hum then return nil end
    SetSpawnManager.DoSetSpawn(quest)
    local startTime = tick()
    while _G.SystemEnabled and not _G.IsBuyingGeppo and LP.Character == char and hrp.Parent and hum.Health > 0 and (hrp.Position - quest.Position).Magnitude > 3 do
        FlySystem.AdjustToTarget(hrp, quest.Position, 3, Config.FLY_SPEED, true)
        task.wait()
        if tick() - startTime > 120 then break end
    end
    if not _G.SystemEnabled or _G.IsBuyingGeppo or hum.Health <= 0 then return nil end
    FlySystem.Stop(hrp)
    task.wait(1.5)
    pcall(function()
        QuestRemote:InvokeServer(unpack({{"npcChat", true}}))
        task.wait(0.5)
        QuestRemote:InvokeServer(unpack({{"takequest", quest.TargetQuestName}}))
        task.wait(0.5)
        QuestRemote:InvokeServer(unpack({{"npcChat", false}}))
    end)
    task.wait(2.5)
    QuestTracker.UpdateHasActiveQuest()
    if cachedHasQuest then return quest end
    return nil
end

