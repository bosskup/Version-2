local CombatSystem = {}
local comboIndex = 1
local lastAttackTime = 0
local attacking = false
local singleCooldownEndTime = 0
local comboHitCount = 0

local aoeComboIndex = 1
local lastAoeAttackTime = 0
local aoeCooldownEndTime = 0

function CombatSystem.SingleAttack(mob)
    if attacking or not mob or not mob:FindFirstChild("HumanoidRootPart") or mob.Humanoid.Health <= 0 then return false end
    if tick() < singleCooldownEndTime then return false end
    attacking = true
    task.spawn(function()
        if tick() - lastAttackTime > 3 then comboIndex = 1 comboHitCount = 0 end
        if comboHitCount >= 5 then
            comboHitCount = 0 comboIndex = 1 singleCooldownEndTime = tick() + Config.COMBO_COOLDOWN attacking = false return
        end
        local anim = PunchAnims[comboIndex]
        if anim then
            pcall(function() CombatRegister:InvokeServer(unpack({{"swingsfx", "Melee", comboIndex, "Ground", false, anim, 2, 1.5}})) end)
            task.wait(Config.ATTACK_DELAY)
            pcall(function() CombatRegister:InvokeServer(unpack({{ "damage", { mob.HumanoidRootPart }, "Melee", { comboIndex, "Ground", "Melee" }, true, mob.HumanoidRootPart.CFrame, aircombo = "Ground" }})) end)
            comboHitCount = comboHitCount + 1
            lastAttackTime = tick()
            if comboIndex < 5 then comboIndex = comboIndex + 1 task.wait(0.05) else comboIndex = 1 end
        end
        attacking = false
    end)
    return true
end

function CombatSystem.AoeAttack(mobs, hrp)
    if attacking or #mobs == 0 then return end
    if tick() < aoeCooldownEndTime then return end
    local targetsHRP = {}
    for _, m in ipairs(mobs) do 
        if m and m:FindFirstChild("HumanoidRootPart") and m.Humanoid and m.Humanoid.Health > 0 then table.insert(targetsHRP, m.HumanoidRootPart) end
    end
    if #targetsHRP == 0 then return end
    attacking = true
    task.spawn(function()
        if tick() - lastAoeAttackTime > 3 and tick() > aoeCooldownEndTime then aoeComboIndex = 1 end
        if aoeComboIndex > 5 then aoeComboIndex = 1 end
        local anim = PunchAnims[aoeComboIndex]
        if anim then
            pcall(function() CombatRegister:InvokeServer(unpack({{"swingsfx", "Melee", aoeComboIndex, "Ground", false, anim, 2, 1.5}})) end)
            task.wait(Config.ATTACK_DELAY)
            pcall(function() CombatRegister:InvokeServer(unpack({{ "damage", targetsHRP, "Melee", { aoeComboIndex, "Ground", "Melee" }, true, hrp.CFrame, aircombo = "Ground" }})) end)
            lastAoeAttackTime = tick()
            if aoeComboIndex == 5 then aoeCooldownEndTime = tick() + Config.COMBO_COOLDOWN aoeComboIndex = 1 else aoeComboIndex = aoeComboIndex + 1 task.wait(0.05) end
        end
        attacking = false
    end)
end

