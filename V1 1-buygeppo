-- PULL BACK SYSTEM
-- ============================================
local PullBackSystem = {}
PullBackSystem.lastCheckTime = 0
PullBackSystem.pullBackVelocity = {}
local monsterLastPosition = {}
local monsterLastSeenTime = {}

function PullBackSystem.Reset()
    PullBackSystem.StopAllPulling()
    PullBackSystem.pullBackVelocity = {}
    monsterLastPosition = {}
    monsterLastSeenTime = {}
    PullBackSystem.lastCheckTime = 0
end

function PullBackSystem.ClearMonsterData(mob)
    monsterLastPosition[mob] = nil
    monsterLastSeenTime[mob] = nil
    if PullBackSystem.pullBackVelocity[mob] then
        pcall(function() PullBackSystem.pullBackVelocity[mob]:Destroy() end)
        PullBackSystem.pullBackVelocity[mob] = nil
    end
end

function PullBackSystem.CreatePullBV(mobHRP)
    local bv = Instance.new("BodyVelocity")
    bv.Name = "PullBackBV"
    bv.MaxForce = Vector3.new(1e7, 1e7, 1e7)
    bv.P = 5e4
    bv.Parent = mobHRP
    return bv
end

function PullBackSystem.PullMonster(mob, targetPos)
    if not mob or not mob:FindFirstChild("HumanoidRootPart") then return end
    local mobHRP = mob.HumanoidRootPart
    local currentPos = mobHRP.Position
    local distance = (currentPos - targetPos).Magnitude
    if distance < 10 then
        if PullBackSystem.pullBackVelocity[mob] then
            PullBackSystem.pullBackVelocity[mob]:Destroy()
            PullBackSystem.pullBackVelocity[mob] = nil
        end
        return true
    end
    if not PullBackSystem.pullBackVelocity[mob] then PullBackSystem.pullBackVelocity[mob] = PullBackSystem.CreatePullBV(mobHRP) end
    local dir = (targetPos - currentPos).Unit
    local speed = math.min(120, distance * 3)
    PullBackSystem.pullBackVelocity[mob].Velocity = dir * speed
    return false
end

function PullBackSystem.CheckAndPullTeleportedMobs(pulledMobs, gatherPoint)
    if not pulledMobs or type(pulledMobs) ~= "table" or #pulledMobs == 0 or not gatherPoint then return {} end
    local currentTime = tick()
    local teleportedMobs = {}
    for _, mob in ipairs(pulledMobs) do
        if mob and mob.Parent and mob:FindFirstChild("HumanoidRootPart") and mob.Humanoid.Health > 0 then
            local currentPos = mob.HumanoidRootPart.Position
            local distanceFromGather = (currentPos - gatherPoint).Magnitude
            if monsterLastPosition[mob] then
                local distanceJump = (currentPos - monsterLastPosition[mob]).Magnitude
                if distanceJump > 30 and distanceFromGather > Config.TELEPORT_THRESHOLD then table.insert(teleportedMobs, mob) end
            end
            monsterLastPosition[mob] = currentPos
            monsterLastSeenTime[mob] = currentTime
        else
            PullBackSystem.ClearMonsterData(mob)
        end
    end
    return teleportedMobs
end

function PullBackSystem.FindNewMobs(targetMobNames, gatherPoint, pulledMobs)
    if not targetMobNames or type(targetMobNames) ~= "table" or #targetMobNames == 0 or not gatherPoint then return {} end
    local newMobs = {}
    if tick() - PullBackSystem.lastCheckTime < 0.5 then return newMobs end
    PullBackSystem.lastCheckTime = tick()
    local folder = workspace:FindFirstChild("NPCs")
    if not folder then return newMobs end
    for _, npc in ipairs(folder:GetChildren()) do
        if npc.Parent and npc:FindFirstChild("Humanoid") and npc.Humanoid.Health > 0 and npc:FindFirstChild("HumanoidRootPart") then
            local isTarget = false
            for _, name in ipairs(targetMobNames) do if npc.Name == name then isTarget = true break end end
            if not isTarget then continue end
            local alreadyPulled = false
            if pulledMobs and type(pulledMobs) == "table" then
                for _, pulled in ipairs(pulledMobs) do if pulled == npc then alreadyPulled = true break end end
            end
            if alreadyPulled then continue end
            local mobPos = npc.HumanoidRootPart.Position
            local distance = (mobPos - gatherPoint).Magnitude
            local yDistance = math.abs(mobPos.Y - gatherPoint.Y)
            if distance < Config.PULL_RADIUS and yDistance < 35 then table.insert(newMobs, npc) end
        end
    end
    return newMobs
end

function PullBackSystem.StopAllPulling()
    for mob, bv in pairs(PullBackSystem.pullBackVelocity) do
        pcall(function() bv:Destroy() end)
        PullBackSystem.pullBackVelocity[mob] = nil
    end
end

