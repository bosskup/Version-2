local FlySystem = {}
local function getOrCreateBV(hrp)
    local bv = hrp:FindFirstChild("FlyBV")
    if not bv then
        bv = Instance.new("BodyVelocity")
        bv.Name = "FlyBV"
        bv.MaxForce = Vector3.new(1e8, 1e8, 1e8)
        bv.P = 1e5
        bv.Parent = hrp
    end
    return bv
end

function FlySystem.Stop(hrp)
    if hrp then
        local bv = hrp:FindFirstChild("FlyBV")
        if bv then bv.Velocity = Vector3.zero end
        hrp.Velocity = Vector3.zero
        hrp.AssemblyLinearVelocity = Vector3.zero
        hrp.AssemblyAngularVelocity = Vector3.zero
    end
end

function FlySystem.Remove(hrp)
    if hrp and hrp:FindFirstChild("FlyBV") then hrp.FlyBV:Destroy() end
    if hrp then hrp.Velocity = Vector3.zero hrp.AssemblyLinearVelocity = Vector3.zero end
end

-- 🔍 ระบบเรดาร์หา Sand และดึงค่า Y มาคำนวณ (สแกนวิละ 1 ครั้ง)
local lastScanTime = 0
local cachedIsOcean = false
local cachedSandY = 0

local function IsOverOceanOptimized(currentPos)
    if tick() - lastScanTime >= 1 then
        lastScanTime = tick()
        local params = RaycastParams.new()
        params.FilterType = Enum.RaycastFilterType.Exclude
        local LP = game:GetService("Players").LocalPlayer
        params.FilterDescendantsInstances = {LP.Character}
        params.IgnoreWater = true -- ทะลุน้ำลงไปหาทรายเลย

        -- ยิงเลเซอร์ลงไป 5000 สตัด เพื่อให้ชัวร์ว่าเจอก้นทะเลแน่ๆ
        local result = workspace:Raycast(currentPos, Vector3.new(0, -5000, 0), params)
        
        -- เช็คว่าเจอวัตถุชื่อ "Sand" และอยู่ใน "WaterStuff" หรือไม่ (กันไปโดนทรายบนบก)
        if result and result.Instance and result.Instance.Name == "Sand" then
            local fullName = result.Instance:GetFullName()
            if fullName:find("WaterStuff") or fullName:find("Env") then
                cachedIsOcean = true
                -- เซฟความสูงของพื้นทราย (Y) เก็บไว้
                cachedSandY = result.Position.Y
            else
                cachedIsOcean = false
            end
        else
            cachedIsOcean = false
        end
    end
    return cachedIsOcean, cachedSandY
end

-- ⚠️ ฟังก์ชันบินหลัก
function FlySystem.AdjustToTarget(hrp, targetPos, stopRadius, speed, useWaterRadar)
    if not targetPos or not hrp then return false end
    stopRadius = stopRadius or Config.STOP_RADIUS
    local distance = (targetPos - hrp.Position).Magnitude
    
    if distance <= stopRadius then
        FlySystem.Stop(hrp)
        return true
    end
    
    local currentSpeed = speed or Config.FLY_SPEED
    if distance < 20 then 
        currentSpeed = math.max(15, currentSpeed * (distance / 20)) 
    end

    local myPos = hrp.Position
    local dir = (targetPos - myPos).Unit

    -- 🌊 ระบบบินเหนือ Sand + 107 (ทำงานเฉพาะส่ง true มา)
    if useWaterRadar then
        local horizontalDist = (Vector3.new(targetPos.X, 0, targetPos.Z) - Vector3.new(myPos.X, 0, myPos.Z)).Magnitude
        
        local isOcean, sandY = IsOverOceanOptimized(myPos)
        
        -- ถ้าระยะห่างเกิน 50 และเช็คเจอทราย WaterStuff
        if horizontalDist > 50 and isOcean then
            -- ล็อคความสูงเป้าหมายให้อยู่เหนือทรายพอดี 107 สตัด
            local targetHeight = sandY + 102
            local tempTarget = Vector3.new(targetPos.X, targetHeight, targetPos.Z)
            
            -- ปรับทิศทางการบินไปที่จุดหมายชั่วคราว
            dir = (tempTarget - myPos).Unit
            
            -- ถ้าตัวละครเด้งสูงเกินไป บังคับกดหัวลงนิดนึง
            if myPos.Y > targetHeight + 5 then
                 dir = Vector3.new(dir.X, -0.5, dir.Z).Unit
            end
        end
    end

    local bv = getOrCreateBV(hrp)
    bv.Velocity = dir * currentSpeed
    
    local lookPos = Vector3.new(targetPos.X, hrp.Position.Y, targetPos.Z)
    if (lookPos - hrp.Position).Magnitude > 0.5 then
        pcall(function() hrp.CFrame = CFrame.lookAt(hrp.Position, lookPos) end)
    end
    
    return false
end

function FlySystem.AdjustToMob(hrp, mob, headOffset)
    if not mob or not mob:FindFirstChild("HumanoidRootPart") then return false end
    local targetPos = mob.HumanoidRootPart.Position + Vector3.new(0, headOffset or Config.HEAD_OFFSET, 0)
    return FlySystem.AdjustToTarget(hrp, targetPos, 2, Config.FLY_SPEED)
end
