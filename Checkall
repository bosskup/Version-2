                break 
            end
            
            -- ยิงคำสั่งเข้าเกม
            pcall(function()
                playGame:FireServer("Main Game")
                print("[System] 🎮 กำลังยิง Remote พยายามเข้า Main Game...")
            end)
        end
    end
end

