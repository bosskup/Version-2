    local TeleportService = game:GetService("TeleportService")

    GuiService.ErrorMessageChanged:Connect(function(errorMessage)
        print("[System] 🔄 ตรวจพบการหลุด! กำลังเข้าเกมใหม่ใน 5 วินาที...")
        task.wait(5)
