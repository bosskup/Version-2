local function bypassOverlap(part)
    if part:IsA("BasePart") then
        part.CanCollide = false
        part.CanQuery = false
        part.CanTouch = false
        for _, child in pairs(part:GetChildren()) do
            if child:IsA("TouchTransmitter") then child:Destroy() end
        end
    end
end

RunService.Stepped:Connect(function()
    if _G.SystemEnabled then
        local char = LP.Character
        if char then
            for _, part in ipairs(char:GetDescendants()) do bypassOverlap(part) end
        end
    end
end)

local function AutoEquip()
    local char = LP.Character
    if not char then return end
    if char:FindFirstChildOfClass("Tool") then return end
    local currentBackpack = LP:FindFirstChild("Backpack")
    if not currentBackpack then return end
    local tool = currentBackpack:FindFirstChild("Melee") or currentBackpack:FindFirstChildOfClass("Tool")
    if tool then tool.Parent = char end
end

