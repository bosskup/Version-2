local FarmManager = {}
local States = { PULL = "PULL", GATHER = "GATHER", KILL = "KILL", KILL_SINGLE = "KILL_SINGLE", WAITING = "WAITING" }
local farmState = States.PULL
local pulledMobs = {}
local targetMobNames = {}

local activeGatherPoints = {} 
local gatherIndex = 1
local activeGatherPoint = nil

local activeQuestData = nil 
local killStartTime = 0
local lockedKillHeight = 0
local lastNPCScan = 0
local currentTargetMob = nil
local gatherWaitTime = nil

function FarmManager.SetQuest(quest)
    if quest then
        targetMobNames = quest.TargetMobs
        activeQuestData = quest 
        if typeof(quest.GatherPoint) == "Vector3" then
            activeGatherPoints = {quest.GatherPoint} activeGatherPoint = quest.GatherPoint
        elseif type(quest.GatherPoint) == "table" and #quest.GatherPoint > 0 then
             activeGatherPoints = quest.GatherPoint gatherIndex = 1 activeGatherPoint = activeGatherPoints[gatherIndex]
        end
    else
        targetMobNames = {} activeGatherPoints = {} activeGatherPoint = nil activeQuestData = nil 
    end
    pulledMobs = {} currentTargetMob = nil farmState = States.PULL
    lockedKillHeight = 0 aoeCooldownEndTime = 0 gatherWaitTime = nil
    PullBackSystem.Reset() 
end

function FarmManager.PullMob(mob)
    if not mob or not mob.Parent then return false end
    for _, m in ipairs(pulledMobs) do if m == mob then return true end end
    table.insert(pulledMobs, mob) return true
end

function FarmManager.CheckTeleportedMobs()
    if not activeGatherPoint or not pulledMobs or type(pulledMobs) ~= "table" or #pulledMobs == 0 then return false end
    local teleportedMobs = PullBackSystem.CheckAndPullTeleportedMobs(pulledMobs, activeGatherPoint)
    local hasTeleported = false
    for _, mob in ipairs(teleportedMobs) do PullBackSystem.PullMonster(mob, activeGatherPoint) hasTeleported = true end
    return hasTeleported
end

function FarmManager.CheckNewMobs()
    if not activeGatherPoint or not targetMobNames or type(targetMobNames) ~= "table" or #targetMobNames == 0 then return false end
    local newMobs = PullBackSystem.FindNewMobs(targetMobNames, activeGatherPoint, pulledMobs)
    local hasNewMobs = false
    for _, mob in ipairs(newMobs) do FarmManager.PullMob(mob) hasNewMobs = true end
    return hasNewMobs
end

function FarmManager.PullAllMobsToGather()
    if not activeGatherPoint then return false end
    if not pulledMobs or type(pulledMobs) ~= "table" or #pulledMobs == 0 then return false end
    local anyPulling = false
    for _, mob in ipairs(pulledMobs) do
        if mob and mob.Parent and mob:FindFirstChild("HumanoidRootPart") then
            local flatMobPos = Vector3.new(mob.HumanoidRootPart.Position.X, 0, mob.HumanoidRootPart.Position.Z)
            local flatGatherPos = Vector3.new(activeGatherPoint.X, 0, activeGatherPoint.Z)
            if (flatMobPos - flatGatherPos).Magnitude > 20 then PullBackSystem.PullMonster(mob, activeGatherPoint) anyPulling = true end
        end
    end
    return anyPulling
end

function FarmManager.Update()
    if not _G.SystemEnabled or not targetMobNames or type(targetMobNames) ~= "table" or #targetMobNames == 0 or not activeGatherPoint then return end
    local char = LP.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local stillAlive = {}
    if pulledMobs and type(pulledMobs) == "table" then
        for _, m in ipairs(pulledMobs) do
            if m and m.Parent and m:FindFirstChild("Humanoid") and m.Humanoid.Health > 0 and m:FindFirstChild("HumanoidRootPart") then
                table.insert(stillAlive, m) else PullBackSystem.ClearMonsterData(m) end
        end
    end
    pulledMobs = stillAlive

    if farmState == States.PULL then
        lockedKillHeight = 0 gatherWaitTime = nil PullBackSystem.StopAllPulling()
        if currentTargetMob and (not currentTargetMob.Parent or currentTargetMob.Humanoid.Health <= 0) then currentTargetMob = nil end
        if not currentTargetMob then
            if tick() - lastNPCScan > 0.3 then
                lastNPCScan = tick()
                local folder = workspace:FindFirstChild("NPCs")
                if folder then
                    for _, npc in ipairs(folder:GetChildren()) do
                        local alreadyPulled = false
                        if pulledMobs and type(pulledMobs) == "table" then
                            for _, p in ipairs(pulledMobs) do if p == npc then alreadyPulled = true break end end
                        end
                        if not alreadyPulled and npc.Parent and npc:FindFirstChild("Humanoid") and npc.Humanoid.Health > 0 then
                            for _, name in ipairs(targetMobNames) do
                                if npc.Name == name then
                                    local yDistance = math.abs(npc.HumanoidRootPart.Position.Y - activeGatherPoint.Y)
                                    if yDistance < 35 then currentTargetMob = npc break end
                                end
                            end
                        end
                        if currentTargetMob then break end
                    end
                end
                if not currentTargetMob then
                    if pulledMobs and type(pulledMobs) == "table" and #pulledMobs > 0 then
                        if #pulledMobs == 1 then farmState = States.KILL_SINGLE killStartTime = tick() else farmState = States.GATHER end
                    else farmState = States.WAITING end
                end
            end
        end
        if currentTargetMob then
            local currentHeadOffset = (activeQuestData and activeQuestData.CustomHeadOffset) or Config.HEAD_OFFSET
            if FlySystem.AdjustToMob(hrp, currentTargetMob, currentHeadOffset) then
                CombatSystem.SingleAttack(currentTargetMob)
                if currentTargetMob.Humanoid.Health < currentTargetMob.Humanoid.MaxHealth then FarmManager.PullMob(currentTargetMob) currentTargetMob = nil end
            end
        end

    elseif farmState == States.GATHER then
        if #pulledMobs == 1 then farmState = States.KILL_SINGLE killStartTime = tick() PullBackSystem.StopAllPulling() return end
        FarmManager.CheckTeleportedMobs() FarmManager.CheckNewMobs() FarmManager.PullAllMobsToGather()
        FlySystem.AdjustToTarget(hrp, activeGatherPoint, 15, Config.FLY_SPEED)
        if not gatherWaitTime then gatherWaitTime = tick() end
        local allClose = true
        if pulledMobs and type(pulledMobs) == "table" then
            for _, mob in ipairs(pulledMobs) do
                if mob and mob:FindFirstChild("HumanoidRootPart") then
                    local flatMobPos = Vector3.new(mob.HumanoidRootPart.Position.X, 0, mob.HumanoidRootPart.Position.Z)
                    local flatGatherPos = Vector3.new(activeGatherPoint.X, 0, activeGatherPoint.Z)
                    if (flatMobPos - flatGatherPos).Magnitude > 20 then allClose = false break end
                end
            end
        end
        if allClose or (tick() - gatherWaitTime > 3) then farmState = States.KILL killStartTime = tick() gatherWaitTime = nil PullBackSystem.StopAllPulling() end
    
    elseif farmState == States.KILL_SINGLE then
        local hasNewMobs = FarmManager.CheckNewMobs()
        if hasNewMobs then farmState = States.GATHER gatherWaitTime = nil return end
        if not pulledMobs or type(pulledMobs) ~= "table" or #pulledMobs == 0 or (tick() - killStartTime > Config.KILL_STUCK_TIMEOUT) then
            pulledMobs = {} farmState = States.PULL PullBackSystem.StopAllPulling()
        else
            local mob = pulledMobs[1]
            if mob and mob:FindFirstChild("HumanoidRootPart") then
                local isReady = false
                if activeQuestData and activeQuestData.LockGatherHeight and activeGatherPoint then
                    isReady = FlySystem.AdjustToTarget(hrp, activeGatherPoint, 3, Config.FLY_SPEED)
                else
                    local currentHeadOffset = (activeQuestData and activeQuestData.CustomHeadOffset) or Config.HEAD_OFFSET
                    isReady = FlySystem.AdjustToMob(hrp, mob, currentHeadOffset)
                end
                if isReady then CombatSystem.SingleAttack(mob) end
            else
                pulledMobs = {} farmState = States.PULL
            end
        end

    elseif farmState == States.KILL then
        local hasTeleported = false
        if activeGatherPoint and pulledMobs and type(pulledMobs) == "table" and #pulledMobs > 0 then hasTeleported = FarmManager.CheckTeleportedMobs() end
        if hasTeleported then farmState = States.GATHER gatherWaitTime = nil return end
        if not pulledMobs or type(pulledMobs) ~= "table" or #pulledMobs == 0 or (tick() - killStartTime > Config.KILL_STUCK_TIMEOUT) then
            pulledMobs = {} farmState = States.PULL PullBackSystem.StopAllPulling()
        else
            if lockedKillHeight == 0 then
                local validMobY = nil
                for _, m in ipairs(pulledMobs) do
                    if m and m:FindFirstChild("HumanoidRootPart") then
                        local dist = (Vector3.new(m.HumanoidRootPart.Position.X, 0, m.HumanoidRootPart.Position.Z) - Vector3.new(activeGatherPoint.X, 0, activeGatherPoint.Z)).Magnitude
                        if dist <= 30 then validMobY = m.HumanoidRootPart.Position.Y break end
                    end
                end
                if validMobY then
                    if activeQuestData and activeQuestData.LockGatherHeight and activeGatherPoint then lockedKillHeight = activeGatherPoint.Y else
                        local currentKillOffset = (activeQuestData and activeQuestData.CustomKillOffset) or Config.KILL_OFFSET
                        lockedKillHeight = validMobY + currentKillOffset
                    end
                else pulledMobs = {} farmState = States.PULL return end
            end
            local flyPos = Vector3.new(activeGatherPoint.X, lockedKillHeight, activeGatherPoint.Z)
            FlySystem.AdjustToTarget(hrp, flyPos, 3)
            CombatSystem.AoeAttack(pulledMobs, hrp)
        end
        
    elseif farmState == States.WAITING then
        if activeGatherPoint and targetMobNames and type(targetMobNames) == "table" and #targetMobNames > 0 then
            local newMobs = PullBackSystem.FindNewMobs(targetMobNames, activeGatherPoint, pulledMobs)
            if #newMobs > 0 then
                for _, mob in ipairs(newMobs) do FarmManager.PullMob(mob) end farmState = States.GATHER
            else
                local distToGather = (hrp.Position - activeGatherPoint).Magnitude
                if distToGather > 40 then FlySystem.AdjustToTarget(hrp, activeGatherPoint, 15, Config.FLY_SPEED) return else
                    if activeGatherPoints and #activeGatherPoints > 1 then
                        gatherIndex = gatherIndex + 1 if gatherIndex > #activeGatherPoints then gatherIndex = 1 end
                        activeGatherPoint = activeGatherPoints[gatherIndex] task.wait(0.5) return
                    end
                end
            end
        end
        FlySystem.Stop(hrp)
    end
end

