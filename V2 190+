local LevelManager = {}
function LevelManager.Get()
    local playerGui = LP:FindFirstChild("PlayerGui")
    if not playerGui then return 1 end
    local success, levelVal = pcall(function()
        return tonumber(playerGui.HUD.Main.Bars.Experience.Detail.Level.Text:match("%d+"))
    end)
    return (success and levelVal) and levelVal or 1
end

function LevelManager.GetBestQuest()
    local myLevel = LevelManager.Get()
    for _, data in ipairs(QUESTS) do
        if myLevel >= data.MinLevel and myLevel <= data.MaxLevel then return data end
    end
    return nil
end

local QuestTracker = {}
function QuestTracker.GetQuestName()
    local playerGui = LP:FindFirstChild("PlayerGui")
    if not playerGui then return nil end
    local questGui = playerGui:FindFirstChild("Quest")
    if questGui and questGui:FindFirstChild("Main") and questGui.Main:FindFirstChild("Info") and questGui.Main.Info:FindFirstChild("Top") then
        local qName = questGui.Main.Info.Top:FindFirstChild("QuestName")
        if qName and qName:IsA("TextLabel") then return qName.Text end
    end
    return nil
end

function QuestTracker.GetProgress()
    local playerGui = LP:FindFirstChild("PlayerGui")
    if not playerGui then return nil, nil end
    local questGui = playerGui:FindFirstChild("Quest")
    if not questGui then return nil, nil end

    local function scan(obj)
        for _, child in ipairs(obj:GetChildren()) do
            if child:IsA("TextLabel") or child:IsA("TextButton") then
                local text = child.Text
                if text then
                    local current, total = text:match("(%d+)/(%d+)")
                    if current and total then return tonumber(current), tonumber(total) end
                    current, total = text:match("(%d+) of (%d+)")
                    if current and total then return tonumber(current), tonumber(total) end
                end
            end
            local c, t = scan(child)
            if c then return c, t end
        end
        return nil, nil
    end
    return scan(questGui)
end

function QuestTracker.IsComplete()
    local current, total = QuestTracker.GetProgress()
    if current and total and total > 0 then return current >= total end
    local playerGui = LP:FindFirstChild("PlayerGui")
    local questGui = playerGui and playerGui:FindFirstChild("Quest")
    if questGui then
        local function checkText(obj)
            for _, child in ipairs(obj:GetChildren()) do
                if child:IsA("TextLabel") or child:IsA("TextButton") then
                    local text = (child.Text or ""):lower()
                    if text:find("return") or text:find("completed") or text:find("done") or text:find("talk to") then
                        return true
                    end
                end
                if checkText(child) then return true end
            end
            return false
        end
        if checkText(questGui) then return true end
    end
    return false
end

function QuestTracker.UpdateHasActiveQuest()
    local playerGui = LP:FindFirstChild("PlayerGui")
    if not playerGui then cachedHasQuest = false return end
    local questGui = playerGui:FindFirstChild("Quest")
    if not questGui then cachedHasQuest = false return end
    local main = questGui:FindFirstChild("Main")
    if questGui:IsA("ScreenGui") and not questGui.Enabled then cachedHasQuest = false return end
    if main and not main.Visible then cachedHasQuest = false return end
    local name = QuestTracker.GetQuestName()
    if not name or name:gsub("%s", "") == "" or name:lower():find("none") or name:lower():find("no quest") or name == "QuestName" or name == "Label" then 
        cachedHasQuest = false
    else
        cachedHasQuest = true
    end
end

-- ============================================
-- 🚀 HYBRID FLY SYSTEM (Tween เดินทางไกล / BodyVelocity ตอนฟาร์ม)
-- ============================================
local FlySystem = {}
local activeTween = nil
local currentTargetPos = nil

function FlySystem.Stop(hrp)
    if activeTween then
        activeTween:Cancel()
        activeTween = nil
        currentTargetPos = nil
    end
    if hrp then
        hrp.Velocity = Vector3.zero
        hrp.AssemblyLinearVelocity = Vector3.zero
        hrp.AssemblyAngularVelocity = Vector3.zero
        local bv = hrp:FindFirstChild("FlyBV")
        if bv then 
            bv.Velocity = Vector3.zero -- สั่งให้หยุด แต่พยุงตัวไว้กลางอากาศ
        end
    end
end

function FlySystem.Remove(hrp)
    FlySystem.Stop(hrp)
    if hrp then
        local bv = hrp:FindFirstChild("FlyBV")
        if bv then bv:Destroy() end
    end
end

function FlySystem.AdjustToTarget(hrp, targetPos, stopRadius, speed, goHigh)
    if not targetPos or not hrp then return false end
    stopRadius = stopRadius or Config.STOP_RADIUS
    local distance = (targetPos - hrp.Position).Magnitude
    
    if distance <= stopRadius then
        FlySystem.Stop(hrp)
        return true
    end
    
    local myPos = hrp.Position
    local finalTarget = targetPos

    -- 🌊 ระบบบินสำหรับเกาะใต้ดิน (ล็อคเพดานบินสูงสุด)
    if goHigh then
        local horizontalDist = (Vector3.new(targetPos.X, 0, targetPos.Z) - Vector3.new(myPos.X, 0, myPos.Z)).Magnitude
        
        local safeHeight = math.max(myPos.Y, targetPos.Y) + 80 
        if safeHeight > -1753 then safeHeight = -1753 end

        if horizontalDist > 60 then
            if myPos.Y < safeHeight - 15 then
                finalTarget = Vector3.new(myPos.X, safeHeight, myPos.Z)
            else
                finalTarget = Vector3.new(targetPos.X, safeHeight, targetPos.Z)
            end
        else
            finalTarget = targetPos
        end
    end

    local distToFinal = (finalTarget - hrp.Position).Magnitude

    -- สร้าง BodyVelocity ไว้พยุงตัว
    local bv = hrp:FindFirstChild("FlyBV")
    if not bv then
        bv = Instance.new("BodyVelocity")
        bv.Name = "FlyBV"
        bv.MaxForce = Vector3.new(1e8, 1e8, 1e8)
        bv.Velocity = Vector3.zero
        bv.Parent = hrp
    end

    -- 🔄 ระบบแยกการทำงาน (Hybrid)
    if distToFinal > 30 then
        -- 🚀 [ระยะไกล] ใช้ TWEEN เพื่อความนุ่มนวลทะลุกำแพง
        bv.Velocity = Vector3.zero -- ปิดแรงดันของ BV ตอนใช้ Tween
        
        if not currentTargetPos or (currentTargetPos - finalTarget).Magnitude > 5 or not activeTween or activeTween.PlaybackState ~= Enum.PlaybackState.Playing then
            if activeTween then activeTween:Cancel() end
            currentTargetPos = finalTarget
            
            local currentSpeed = speed or Config.FLY_SPEED
            local timeToReach = distToFinal / currentSpeed
            local tInfo = TweenInfo.new(timeToReach, Enum.EasingStyle.Linear)

            local lookPos = Vector3.new(finalTarget.X, hrp.Position.Y, finalTarget.Z)
            local lookRot = CFrame.new(hrp.Position)
            if (lookPos - hrp.Position).Magnitude > 0.1 then
                lookRot = CFrame.lookAt(hrp.Position, lookPos).Rotation
            else
                lookRot = CFrame.lookAt(hrp.Position, finalTarget).Rotation
            end

            activeTween = TweenService:Create(hrp, tInfo, {CFrame = CFrame.new(finalTarget) * lookRot})
            activeTween:Play()
        end
    else
        -- ⚔️ [ระยะใกล้/ฟาร์มมอน] ปิด Tween ใช้ BODYVELOCITY แทนเพื่อความนิ่ง
        if activeTween then 
            activeTween:Cancel() 
            activeTween = nil
            currentTargetPos = nil
        end
        
        local currentSpeed = speed or Config.FLY_SPEED
        local dir = (finalTarget - hrp.Position).Unit
        bv.Velocity = dir * currentSpeed
        
        -- หันหน้าเข้าหามอนสเตอร์
        local lookPos = Vector3.new(finalTarget.X, hrp.Position.Y, finalTarget.Z)
        if (lookPos - hrp.Position).Magnitude > 0.1 then
            hrp.CFrame = CFrame.new(hrp.Position, lookPos)
        end
    end

    return false
end

function FlySystem.AdjustToMob(hrp, mob, headOffset)
    if not mob or not mob:FindFirstChild("HumanoidRootPart") then return false end
    local targetPos = mob.HumanoidRootPart.Position + Vector3.new(0, headOffset or Config.HEAD_OFFSET, 0)
    return FlySystem.AdjustToTarget(hrp, targetPos, 2, Config.FLY_SPEED)
end

function FlySystem.IsFlyingFar(hrp)
    if not currentTargetPos or not hrp then return false end
    return (hrp.Position - currentTargetPos).Magnitude > 30
end

-- ============================================
-- PULL BACK SYSTEM
-- ============================================
local PullBackSystem = {}
PullBackSystem.lastCheckTime = 0
PullBackSystem.pullBackVelocity = {}
local monsterLastPosition = {}
local monsterLastSeenTime = {}

function PullBackSystem.Reset()
    PullBackSystem.StopAllPulling()
    PullBackSystem.pullBackVelocity = {}
    monsterLastPosition = {}
    monsterLastSeenTime = {}
    PullBackSystem.lastCheckTime = 0
end

function PullBackSystem.ClearMonsterData(mob)
    monsterLastPosition[mob] = nil
    monsterLastSeenTime[mob] = nil
    if PullBackSystem.pullBackVelocity[mob] then
        pcall(function() PullBackSystem.pullBackVelocity[mob]:Destroy() end)
        PullBackSystem.pullBackVelocity[mob] = nil
    end
end

function PullBackSystem.CreatePullBV(mobHRP)
    local bv = Instance.new("BodyVelocity")
    bv.Name = "PullBackBV"
    bv.MaxForce = Vector3.new(1e7, 1e7, 1e7)
    bv.P = 5e4
    bv.Parent = mobHRP
    return bv
end

function PullBackSystem.PullMonster(mob, targetPos)
    if not mob or not mob:FindFirstChild("HumanoidRootPart") then return end
    local mobHRP = mob.HumanoidRootPart
    local currentPos = mobHRP.Position
    local distance = (currentPos - targetPos).Magnitude
    if distance < 10 then
        if PullBackSystem.pullBackVelocity[mob] then
            PullBackSystem.pullBackVelocity[mob]:Destroy()
            PullBackSystem.pullBackVelocity[mob] = nil
        end
        return true
    end
    if not PullBackSystem.pullBackVelocity[mob] then PullBackSystem.pullBackVelocity[mob] = PullBackSystem.CreatePullBV(mobHRP) end
    local dir = (targetPos - currentPos).Unit
    local speed = math.min(120, distance * 3)
    PullBackSystem.pullBackVelocity[mob].Velocity = dir * speed
    return false
end

function PullBackSystem.CheckAndPullTeleportedMobs(pulledMobs, gatherPoint)
    if not pulledMobs or type(pulledMobs) ~= "table" or #pulledMobs == 0 or not gatherPoint then return {} end
    local currentTime = tick()
    local teleportedMobs = {}
    for _, mob in ipairs(pulledMobs) do
        if mob and mob.Parent and mob:FindFirstChild("HumanoidRootPart") and mob.Humanoid.Health > 0 then
            local currentPos = mob.HumanoidRootPart.Position
            local distanceFromGather = (currentPos - gatherPoint).Magnitude
            if monsterLastPosition[mob] then
                local distanceJump = (currentPos - monsterLastPosition[mob]).Magnitude
                if distanceJump > 30 and distanceFromGather > Config.TELEPORT_THRESHOLD then table.insert(teleportedMobs, mob) end
            end
            monsterLastPosition[mob] = currentPos
            monsterLastSeenTime[mob] = currentTime
        else
            PullBackSystem.ClearMonsterData(mob)
        end
    end
    return teleportedMobs
end

function PullBackSystem.FindNewMobs(targetMobNames, gatherPoint, pulledMobs)
    if not targetMobNames or type(targetMobNames) ~= "table" or #targetMobNames == 0 or not gatherPoint then return {} end
    local newMobs = {}
    if tick() - PullBackSystem.lastCheckTime < 0.5 then return newMobs end
    PullBackSystem.lastCheckTime = tick()
    local folder = workspace:FindFirstChild("NPCs")
    if not folder then return newMobs end
    for _, npc in ipairs(folder:GetChildren()) do
        if npc.Parent and npc:FindFirstChild("Humanoid") and npc.Humanoid.Health > 0 and npc:FindFirstChild("HumanoidRootPart") then
            local isTarget = false
            for _, name in ipairs(targetMobNames) do if npc.Name == name then isTarget = true break end end
            if not isTarget then continue end
            local alreadyPulled = false
            if pulledMobs and type(pulledMobs) == "table" then
                for _, pulled in ipairs(pulledMobs) do if pulled == npc then alreadyPulled = true break end end
            end
            if alreadyPulled then continue end
            local mobPos = npc.HumanoidRootPart.Position
            local distance = (mobPos - gatherPoint).Magnitude
            local yDistance = math.abs(mobPos.Y - gatherPoint.Y)
            if distance < Config.PULL_RADIUS and yDistance < 35 then table.insert(newMobs, npc) end
        end
    end
    return newMobs
end

function PullBackSystem.StopAllPulling()
    for mob, bv in pairs(PullBackSystem.pullBackVelocity) do
        pcall(function() bv:Destroy() end)
        PullBackSystem.pullBackVelocity[mob] = nil
    end
end

